<Footer>:
    size_hint_y: None
    height: "36dp"
    orientation: "horizontal"
    padding: "16dp", "0dp"

    canvas.before:
        # Background: #0F172A (Slate 900) - blends with body
        Color:
            rgba: 0.059, 0.090, 0.165, 1.0
        Rectangle:
            pos: self.pos
            size: self.size
        
        # Subtle Top Border: #334155 (Slate 700)
        Color:
            rgba: 0.200, 0.255, 0.333, 1.0
        Rectangle:
            pos: self.x, self.top - 1
            size: self.width, 1

    Label:
        text: "v" + root.version
        color: 0.392, 0.455, 0.541, 1.0  # #64748B (Slate 500)
        font_size: "12sp"
        halign: "center"
        valign: "middle"
        text_size: self.size