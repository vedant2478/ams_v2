<Header>:
    size_hint_y: None
    height: "64dp"
    padding: "16dp", "8dp"
    spacing: "12dp"
    orientation: "horizontal"

    canvas.before:
        # Background: #0F172A (Slate 900) - blends with body
        Color:
            rgba: 0.059, 0.090, 0.165, 1.0
        Rectangle:
            pos: self.pos
            size: self.size

    # ---- Status pill (left) ----
    BoxLayout:
        size_hint_x: None
        width: status_label.texture_size[0] + dp(32)
        size_hint_y: None
        height: "32dp"
        pos_hint: {"center_y": 0.5}
        canvas.before:
            Color:
                # Green for Ready (#10B981), Amber for Busy (#F59E0B), Red for Error (#EF4444)
                rgba: (0.063, 0.725, 0.506, 1.0) if root.status_text == "SYSTEM READY" else (0.961, 0.620, 0.043, 1.0) if root.status_text == "BUSY" else (0.937, 0.267, 0.267, 1.0)
            RoundedRectangle:
                radius: [16]
                pos: self.pos
                size: self.size
        Label:
            id: status_label
            text: root.status_text if root.status_text else "SYSTEM READY"
            color: 1, 1, 1, 1
            halign: "center"
            font_size: "13sp"
            bold: True
            letter_spacing: "1sp"

    # ---- Site name (center) ----
    Label:
        text: getattr(root, 'site_text', getattr(app, 'site_name', 'SITE'))
        halign: "center"
        color: 0.973, 0.980, 0.988, 1.0  # #F8FAFC
        font_size: "26sp"
        bold: True
        letter_spacing: "4sp"

    # ---- Time (right) ----
    Label:
        text: root.time_text
        halign: "right"
        color: 0.580, 0.639, 0.722, 1.0  # #94A3B8 (Slate 400)
        font_size: "15sp"
        bold: True
        size_hint_x: None
        width: "100dp"