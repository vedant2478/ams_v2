#:kivy 2.3.0
#:import dp kivy.metrics.dp

<ActivityCard>:
    key_name: ""
    taken_text: ""
    returned_text: ""
    orientation: "vertical"
    size_hint_y: None
    height: "96dp"
    padding: "16dp"
    spacing: "8dp"
    canvas.before:
        Color:
            # Slate 900
            rgba: 0.059, 0.090, 0.165, 1.0
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12]

    Label:
        text: root.key_name
        font_size: "18sp"
        bold: True
        color: 0.973, 0.980, 0.988, 1.0  # Slate 50
        size_hint_y: None
        height: "26dp"
        halign: "left"
        valign: "middle"
        text_size: self.size

    Label:
        text: "Taken    :  " + root.taken_text
        font_size: "14sp"
        color: 0.580, 0.639, 0.722, 1.0  # Slate 400
        size_hint_y: None
        height: "20dp"
        halign: "left"
        valign: "middle"
        text_size: self.size

    Label:
        text: "Returned :  " + root.returned_text
        font_size: "14sp"
        color: 0.580, 0.639, 0.722, 1.0  # Slate 400
        size_hint_y: None
        height: "20dp"
        halign: "left"
        valign: "middle"
        text_size: self.size


<ActivityDoneScreen>:
    name: "activity_done"

    FloatLayout:

        Header:
            pos_hint: {"top": 1}

        # (GradientBackground removed - BaseScreen provides SolidBackground)

        BoxLayout:
            orientation: "vertical"
            size_hint: None, None
            size: "540dp", "640dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.50}
            padding: "30dp"
            spacing: "24dp"

            # Big check
            Widget:
                size_hint_y: None
                height: "140dp"
                canvas:
                    Color:
                        # Emerald 500
                        rgba: 0.063, 0.725, 0.506, 1.0
                    Line:
                        circle: (self.center_x, self.center_y, 60)
                        width: 5
                    Line:
                        points: self.center_x - 30, self.center_y, self.center_x - 5, self.center_y - 25, self.center_x + 35, self.center_y + 25
                        width: 5

            Label:
                text: "ACTIVITY COMPLETED"
                font_size: "26sp"
                bold: True
                letter_spacing: "3sp"
                color: 0.063, 0.725, 0.506, 1.0  # Emerald 500
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: "40dp"

            # Cards panel
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: "16dp"
                spacing: "12dp"
                canvas.before:
                    Color:
                        # Slate 800
                        rgba: 0.118, 0.161, 0.231, 1.0
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [16]

                ScrollView:
                    size_hint_y: None
                    height: "260dp"
                    do_scroll_x: False
                    bar_width: dp(6)
                    bar_color: 0.200, 0.255, 0.333, 0.8
                    bar_inactive_color: 0.118, 0.161, 0.231, 0.4

                    BoxLayout:
                        id: cards_container
                        orientation: "vertical"
                        size_hint_y: None
                        padding: "8dp"
                        spacing: "12dp"
                        height: self.minimum_height

            Widget:
                size_hint_y: None
                height: "10dp"

            Label:
                text: "Auto-dismissing in [b]" + str(root.countdown) + "[/b] seconds..."
                markup: True
                font_size: "15sp"
                color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                size_hint_y: None
                height: "26dp"

            Widget:
                size_hint_y: None
                height: "16dp"

            Button:
                text: "RETURN TO MAIN MENU"
                size_hint_y: None
                height: "56dp"
                font_size: "16sp"
                letter_spacing: "2sp"
                bold: True
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.on_return_pressed()

                canvas.before:
                    Color:
                        # Blue 600 (#2563EB)
                        rgba: 0.145, 0.388, 0.914, 0.9
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]

                canvas.after:
                    Color:
                        # Blue 400 (#60A5FA)
                        rgba: 0.376, 0.647, 0.980, 0.8
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 12)
                        width: 1.5

        Footer:
            pos_hint: {"y": 0}
            version_text: "12.9.3"
