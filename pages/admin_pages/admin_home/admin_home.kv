<AdminScreen>:
    BoxLayout:
        orientation: "vertical"

        # ================= HEADER =================
        Header:
            title: "ADMIN CONFIGURATION"
            pos_hint: {"top": 1}

        # ================= BODY =================
        FloatLayout:
            size_hint_y: 1

            # (GradientBackground removed - BaseScreen provides SolidBackground)

            # -------- CENTER PANEL --------
            BoxLayout:
                orientation: "vertical"
                spacing: "40dp"
                size_hint: None, None
                size: "520dp", "420dp"
                pos_hint: {"center_x": 0.5, "center_y": 0.55}

                # -------- TITLE --------
                Label:
                    text: "ADMIN SETTINGS"
                    font_size: "26sp"
                    color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                    letter_spacing: "3sp"
                    size_hint_y: None
                    height: "50dp"

                # -------- PEG REGISTRATION --------
                Button:
                    text: "PEG REGISTRATION"
                    size_hint_y: None
                    height: "90dp"
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                    font_size: "20sp"
                    letter_spacing: "2sp"
                    on_release: root.open_peg_registration()

                    canvas.before:
                        # Blue 600 background (#2563EB)
                        Color:
                            rgba: 0.145, 0.388, 0.914, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [16]

                    canvas.after:
                        # Bright border (#60A5FA - Blue 400)
                        Color:
                            rgba: 0.376, 0.647, 0.980, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 16)
                            width: 1.5

                # -------- CARD REGISTRATION --------
                Button:
                    text: "CARD REGISTRATION"
                    size_hint_y: None
                    height: "90dp"
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                    font_size: "20sp"
                    letter_spacing: "2sp"
                    on_release: root.open_card_registration()

                    canvas.before:
                        # Blue 600 background (#2563EB)
                        Color:
                            rgba: 0.145, 0.388, 0.914, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [16]

                    canvas.after:
                        # Bright border (#60A5FA - Blue 400)
                        Color:
                            rgba: 0.376, 0.647, 0.980, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 16)
                            width: 1.5

            # -------- BACK BUTTON (BOTTOM LEFT) --------
            Button:
                text: "< Back"
                size_hint: None, None
                size: "120dp", "48dp"
                pos_hint: {"x": 0.03, "y": 0.03}
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                font_size: "16sp"
                bold: True
                on_release: root.go_home()

                canvas.before:
                    Color:
                        rgba: 0.118, 0.161, 0.231, 1.0  # Slate 800
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]
