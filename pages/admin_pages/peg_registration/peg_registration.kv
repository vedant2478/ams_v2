<PegScanScreen>:
    FloatLayout:

        # ===== Header =====
        Header:
            pos_hint: {"top": 1}
            status_text: "BUSY"
            site_text: app.site_name if hasattr(app, 'site_name') else "SITE"
            time_text: root.time_text
    
        # ====== BACK BAR ======
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "48dp"
            padding: "16dp", 0
            pos_hint: {"top": .95}

            Button:
                text: "< Cancel"
                size_hint_x: None
                width: "100dp"
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                font_size: "16sp"
                bold: True
                on_release: root.cancel_scan()
                disabled: root.scan_in_progress

            Widget:
        
        # ===== Main Content =====
        BoxLayout:
            orientation: "vertical"
            spacing: "26dp"
            size_hint: None, None
            size: "500dp", "520dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.52}

            Label:
                text: "PEG REGISTRATION"
                font_size: "22sp"
                bold: True
                letter_spacing: "2sp"
                color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                size_hint_y: None
                height: "40dp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            # ===== Icon =====
            Image:
                source: "assets/icons/card_scan_frame.png"
                size_hint: None, None
                size: "180dp", "180dp"
                fit_mode: "contain"
                pos_hint: {"center_x": 0.5}

            # ===== Progress Bar =====
            BoxLayout:
                size_hint: None, None
                size: "360dp", "14dp"
                pos_hint: {"center_x": 0.5}
                canvas.before:
                    Color:
                        # Slate 800 Base
                        rgba: 0.118, 0.161, 0.231, 1.0
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [7]

                Widget:
                    size_hint_x: root.progress / 100.0
                    size_hint_y: 1
                    canvas:
                        Color:
                            # Emerald 500 complete, Rose 500 error, Sky 500 loading
                            rgba: (0.063, 0.725, 0.506, 1.0) if root.scan_state == "complete" else (0.937, 0.267, 0.267, 1.0) if root.scan_state == "error" else (0.055, 0.651, 0.933, 1.0)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [7]

            # ===== Status Text =====
            Label:
                text: root.status_text
                font_size: "18sp"
                bold: True
                letter_spacing: "1sp"
                color: (0.063, 0.725, 0.506, 1.0) if root.scan_state == "complete" else (0.937, 0.267, 0.267, 1.0) if root.scan_state == "error" else (0.973, 0.980, 0.988, 1.0)
                size_hint_y: None
                height: "30dp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            # ===== Instruction Text =====
            Label:
                text: root.instruction_text
                font_size: "15sp"
                color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                size_hint_y: None
                height: "50dp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            # ===== Done Button =====
            Button:
                text: "DONE"
                size_hint: None, None
                size: "240dp", "56dp"
                pos_hint: {"center_x": 0.5}
                background_normal: ""
                background_color: (0.063, 0.725, 0.506, 1.0) if root.scan_state == "complete" else (0.118, 0.161, 0.231, 0.5)
                color: 1, 1, 1, 1
                font_size: "18sp"
                letter_spacing: "2sp"
                bold: True
                disabled: root.scan_state != "complete"
                opacity: 1 if root.scan_state == "complete" else 0.4
                on_release: root.go_home()

        # ===== Footer =====
        Footer:
            pos_hint: {"y": 0}
            version_text: "Version: V1.1"


<PegScanCompletePopup>:
    size_hint: 0.5, 0.35
    auto_dismiss: False
    
    BoxLayout:
        orientation: "vertical"
        padding: "24dp"
        spacing: "24dp"
        canvas.before:
            Color:
                # Slate 800
                rgba: 0.118, 0.161, 0.231, 1.0
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [16]

        Label:
            text: "✓ Success"
            font_size: "32sp"
            color: 0.063, 0.725, 0.506, 1.0  # Emerald 500
            bold: True
            size_hint_y: None
            height: "50dp"
            halign: "center"

        Label:
            text: root.message_text
            font_size: "16sp"
            color: 0.973, 0.980, 0.988, 1.0  # Slate 50
            size_hint_y: None
            height: "40dp"
            halign: "center"
            valign: "middle"
            text_size: self.size

        Button:
            text: "OK"
            size_hint: None, None
            size: "180dp", "50dp"
            pos_hint: {"center_x": 0.5}
            background_normal: ""
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            font_size: "16sp"
            letter_spacing: "2sp"
            bold: True
            on_release: root.dismiss()

            canvas.before:
                Color:
                    rgba: 0.145, 0.388, 0.914, 1  # Blue 600
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [12]
