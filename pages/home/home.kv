<HomeScreen>:
    BoxLayout:
        orientation: "vertical"

        # ================= HEADER =================
        Header:
            pos_hint: {"top": 1}

        # ================= BODY =================
        FloatLayout:
            size_hint_y: 1

            # (GradientBackground removed - BaseScreen auto-injects SolidBackground)

            # -------- CENTER CONTENT --------
            BoxLayout:
                orientation: "vertical"
                spacing: "24dp"
                size_hint: None, None
                size: "600dp", "600dp"
                pos_hint: {"center_x": 0.5, "center_y": 0.50}

                Widget:
                    size_hint_y: 0.10

                # -------- TIME --------
                Label:
                    text: root.time_text
                    font_size: "140sp"
                    color: 0.973, 0.980, 0.988, 1.0  # F8FAFC
                    bold: True
                    size_hint_y: None
                    height: "170dp"

                Widget:
                    size_hint_y: None
                    height: "10dp"

                # -------- SITE NAME --------
                Label:
                    text: root.site_name
                    font_size: "42sp"
                    color: 0.580, 0.639, 0.722, 1.0  # 94A3B8
                    bold: True
                    size_hint_y: None
                    height: "55dp"
                    letter_spacing: "4sp"

                Widget:
                    size_hint_y: None
                    height: "20dp"

                # -------- STATUS --------
                Label:
                    text: "READY" if root.status_text == "SYSTEM READY" else root.status_text
                    font_size: "26sp"
                    # Emerald Green for READY
                    color: (0.063, 0.725, 0.506, 1.0) if root.status_text == "SYSTEM READY" else (0.58, 0.64, 0.72, 1.0)
                    bold: True
                    size_hint_y: None
                    height: "40dp"
                    letter_spacing: "5sp"

                Widget:
                    size_hint_y: None
                    height: "55dp"

                # -------- START BUTTON --------
                Button:
                    text: "START"
                    size_hint: None, None
                    size: "180dp", "180dp"
                    pos_hint: {"center_x": 0.5}
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: "28sp"
                    bold: True
                    letter_spacing: "3sp"
                    on_release: root.on_start_pressed()

                    canvas.before:
                        # Soft Glow Effect (Outer)
                        Color:
                            rgba: 0.063, 0.725, 0.506, 0.2
                        Ellipse:
                            pos: self.x - 12, self.y - 12
                            size: self.width + 24, self.height + 24

                        # Core Button: Emerald Green (#10B981)
                        Color:
                            rgba: 0.063, 0.725, 0.506, 1.0
                        Ellipse:
                            pos: self.pos
                            size: self.size

                    canvas.after:
                        # Inner Highlight Border
                        Color:
                            rgba: 0.208, 0.824, 0.631, 0.8
                        Line:
                            circle: (self.center_x, self.center_y, self.width / 2)
                            width: 2.0

                Widget:
                    size_hint_y: 0.15

            # ================= CONFIG BUTTON =================
            Button:
                text: "⚙"
                size_hint: None, None
                size: "60dp", "60dp"
                pos_hint: {"x": 0.03, "y": 0.03}
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.580, 0.639, 0.722, 1.0  # 94A3B8
                font_size: "30sp"
                on_release: root.open_config()

                canvas.before:
                    # Slate 800 background
                    Color:
                        rgba: 0.118, 0.161, 0.231, 0.9
                    Ellipse:
                        pos: self.pos
                        size: self.size

                canvas.after:
                    # Slate 600 Border
                    Color:
                        rgba: 0.278, 0.353, 0.471, 0.8
                    Line:
                        circle: (self.center_x, self.center_y, self.width / 2)
                        width: 1.5

        # ================= FOOTER =================
        Footer:
            version: "12.9.3"
