#:kivy 2.1.0
#:import dp kivy.metrics.dp

<KeyDashboardScreen>:
    FloatLayout:

        # =====================================================
        # FULL-SCREEN LAYOUT
        # =====================================================
        BoxLayout:
            orientation: "vertical"
            size_hint: 1, 1

            # ================= HEADER =================
            Header:
                size_hint_y: None
                height: dp(64)
                status_text: "BUSY"

            # ====== BACK BAR ======
            BoxLayout:
                size_hint_y: None
                height: dp(48)
                padding: dp(16), 0
                spacing: dp(12)
                canvas.before:
                    Color:
                        # Slate 800
                        rgba: 0.118, 0.161, 0.231, 0.95
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Button:
                    text: "< Back"
                    size_hint_x: None
                    width: dp(100)
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                    font_size: "16sp"
                    bold: True
                    on_release: root.go_back()

                Widget:

                # User badge
                BoxLayout:
                    size_hint_x: None
                    width: dp(190)
                    padding: dp(12), dp(4)
                    pos_hint: {"center_y": 0.5}
                    size_hint_y: None
                    height: dp(32)
                    canvas.before:
                        Color:
                            # Slate 700
                            rgba: 0.200, 0.255, 0.333, 1.0
                        RoundedRectangle:
                            radius: [16]
                            pos: self.pos
                            size: self.size
                    Label:
                        text: root.user_name
                        color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                        font_size: "13sp"
                        bold: True
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

            # ================= BODY =================
            FloatLayout:
                size_hint_y: 1

                BoxLayout:
                    orientation: "vertical"
                    size_hint: 0.94, 0.96
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    padding: dp(16)
                    spacing: dp(16)

                    # -------- ACTIVITY BLOCK --------
                    BoxLayout:
                        size_hint_y: None
                        height: dp(76)
                        spacing: dp(16)

                        # Activity code pill
                        BoxLayout:
                            padding: dp(16), dp(8)
                            size_hint_x: 0.45
                            canvas.before:
                                Color:
                                    # Blue 500 (Vibrant blue)
                                    rgba: 0.231, 0.510, 0.965, 1.0
                                RoundedRectangle:
                                    radius: [16]
                                    pos: self.pos
                                    size: self.size
                            BoxLayout:
                                orientation: "vertical"
                                spacing: dp(2)
                                Label:
                                    text: "ACTIVITY CODE"
                                    font_size: "11sp"
                                    color: 0.85, 0.92, 1.0, 1.0
                                    bold: True
                                    halign: "left"
                                    text_size: self.size
                                    size_hint_y: 0.40
                                Label:
                                    text: root.activity_code
                                    bold: True
                                    color: 1, 1, 1, 1
                                    font_size: "24sp"
                                    halign: "left"
                                    text_size: self.size
                                    size_hint_y: 0.60

                        # Activity name + timer
                        BoxLayout:
                            padding: dp(16), dp(8)
                            size_hint_x: 0.55
                            canvas.before:
                                Color:
                                    # Slate 800
                                    rgba: 0.118, 0.161, 0.231, 1.0
                                RoundedRectangle:
                                    radius: [16]
                                    pos: self.pos
                                    size: self.size
                            BoxLayout:
                                orientation: "vertical"
                                spacing: dp(2)
                                Label:
                                    text: root.activity_name
                                    font_size: "13sp"
                                    color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                                    halign: "right"
                                    text_size: self.size
                                    size_hint_y: 0.45
                                Label:
                                    text: root.time_remaining + "s remaining"
                                    font_size: "16sp"
                                    # Emerald 500
                                    color: 0.063, 0.725, 0.506, 1.0
                                    bold: True
                                    halign: "right"
                                    text_size: self.size
                                    size_hint_y: 0.55

                    # -------- PROGRESS BAR --------
                    BoxLayout:
                        size_hint_y: None
                        height: dp(8)
                        canvas.before:
                            Color:
                                # Slate 800
                                rgba: 0.118, 0.161, 0.231, 1.0
                            RoundedRectangle:
                                radius: [4]
                                pos: self.pos
                                size: self.size

                        # Filled portion — bound to progress_value (0.0 to 1.0)
                        Widget:
                            size_hint_x: root.progress_value
                            canvas:
                                Color:
                                    # Emerald 500
                                    rgba: 0.063, 0.725, 0.506, 1.0
                                RoundedRectangle:
                                    radius: [4]
                                    pos: self.pos
                                    size: self.size

                    # -------- KEY COUNT --------
                    BoxLayout:
                        size_hint_y: None
                        height: dp(28)

                        Label:
                            text: "KEYS  ( " + str(len(root.keys_data)) + " )"
                            font_size: "14sp"
                            bold: True
                            color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                            halign: "left"
                            text_size: self.size

                        Widget:

                        Label:
                            text: "Tap a key to close session"
                            font_size: "12sp"
                            color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                            halign: "right"
                            text_size: self.size

                    # -------- KEY LIST --------
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: 1
                        padding: dp(12)
                        spacing: dp(8)
                        canvas.before:
                            Color:
                                # Very dark slate (Slate 950 essentially)
                                rgba: 0.043, 0.067, 0.125, 1.0
                            RoundedRectangle:
                                radius: [16]
                                pos: self.pos
                                size: self.size

                        ScrollView:
                            do_scroll_x: False
                            bar_width: dp(6)
                            bar_color: 0.200, 0.255, 0.333, 0.8
                            bar_inactive_color: 0.118, 0.161, 0.231, 0.4

                            GridLayout:
                                id: key_grid
                                cols: 1
                                spacing: dp(8)
                                padding: dp(4)
                                size_hint_y: None
                                height: self.minimum_height
                                row_force_default: True
                                row_default_height: dp(72)

            # ================= FOOTER =================
            Footer:
                size_hint_y: None
                height: dp(36)
                version: "12.9.3"


<KeyItem>:
    size_hint_y: None
    height: dp(72)
    padding: dp(16), dp(8)
    spacing: dp(16)

    canvas.before:
        Color:
            # Slate 800 background for items
            rgba: 0.118, 0.161, 0.231, 1.0
        RoundedRectangle:
            radius: [12]
            pos: self.pos
            size: self.size
        # Left accent line using root.status_color from python
        Color:
            rgba: root.status_color
        RoundedRectangle:
            radius: [12, 0, 0, 12]
            pos: self.x, self.y
            size: dp(6), self.height

    # -------- KEY NAME --------
    Label:
        text: root.key_name
        color: 0.973, 0.980, 0.988, 1.0  # Slate 50
        font_size: "18sp"
        bold: True
        halign: "left"
        valign: "middle"
        text_size: self.size

    # -------- STATUS INDICATOR --------
    BoxLayout:
        size_hint_x: None
        width: dp(100)
        spacing: dp(10)
        padding: dp(8), 0
        pos_hint: {"center_y": 0.5}

        Widget:
            size_hint_x: None
            width: dp(20)
            canvas:
                Color:
                    rgba: root.status_color
                Ellipse:
                    pos: self.center_x - dp(8), self.center_y - dp(8)
                    size: dp(16), dp(16)

        Label:
            text: root.status_text
            color: root.status_color
            font_size: "17sp"
            bold: True
            valign: "middle"
            halign: "center"
            text_size: self.size
