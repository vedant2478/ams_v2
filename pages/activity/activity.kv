<ActivityCodeScreen@BaseScreen>:
    name: "activity_code"

    FloatLayout:

        # ===== Header =====
        Header:
            pos_hint: {"top": 1}
        
        # ====== BACK BAR ======
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "48dp"
            padding: "16dp", 0
            spacing: "12dp"
            pos_hint: {"top": .938}

            Button:
                text: "< Home"
                size_hint_x: None
                width: "100dp"
                background_normal: ""
                background_color: 0, 0, 0, 0   # fully transparent
                color: 0.580, 0.639, 0.722, 1.0  # Slate 400
                font_size: "16sp"
                bold: True
                on_release: root.go_back()

            Widget:

        # ===== Main Content =====
        BoxLayout:
            orientation: "vertical"
            spacing: "26dp"
            size_hint: None, None
            size: "520dp", "720dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.52}

            # ---- Title ----
            Label:
                text: "ACTIVITY CODE ENTRY"
                font_size: "22sp"
                bold: True
                letter_spacing: "2sp"
                color: 0.973, 0.980, 0.988, 1.0  # Slate 50
                size_hint_y: None
                height: "40dp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            # ---- Code Dots ----
            BoxLayout:
                orientation: "horizontal"
                spacing: "20dp"
                size_hint: None, None
                height: "32dp"
                width: self.minimum_width
                pos_hint: {"center_x": 0.5}

                # Dot 1
                Widget:
                    size_hint: None, None
                    size: "20dp", "20dp"
                    canvas:
                        Color:
                            # Blue 500 if active, Slate 600 if empty
                            rgba: (0.231, 0.510, 0.965, 1.0) if root.code_length >= 1 else (0.278, 0.353, 0.471, 1.0)
                        Ellipse:
                            pos: self.pos
                            size: self.size

                # Dot 2
                Widget:
                    size_hint: None, None
                    size: "20dp", "20dp"
                    canvas:
                        Color:
                            rgba: (0.231, 0.510, 0.965, 1.0) if root.code_length >= 2 else (0.278, 0.353, 0.471, 1.0)
                        Ellipse:
                            pos: self.pos
                            size: self.size

            # ---- Status Message ----
            Label:
                text: root.message
                font_size: "16sp"
                # Amber 500 for messages
                color: (0.961, 0.620, 0.043, 1.0) if root.message else (1,1,1,0)
                size_hint_y: None
                height: "30dp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            Widget:
                size_hint_y: None
                height: "12dp"

            # ---- Divider ----
            Widget:
                size_hint_y: None
                height: "1dp"
                canvas:
                    Color:
                        rgba: 0.118, 0.161, 0.231, 1.0  # Slate 800
                    Rectangle:
                        pos: self.pos
                        size: self.size

            Widget:
                size_hint_y: None
                height: "10dp"

            # ---- Keypad ----
            Keypad:
                callback: root.on_keypad
                size_hint: None, None
                size: "480dp", "440dp"
                pos_hint: {"center_x": 0.5}

        # ===== Footer =====
        Footer:
            pos_hint: {"y": 0}
            version_text: "12.9.3"
